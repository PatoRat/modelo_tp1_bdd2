generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model Cliente {
  id      Int      @id @default(autoincrement())
  nombre  String
  email   String   @unique
  pedidos Pedido[]
}

model Pedido {
  id         Int        @id @default(autoincrement())
  fecha      DateTime
  productos  Producto[] @relation(name: "DetalleProductoEnPedido")
  costoTotal Float
  cliente    Cliente?   @relation(fields: [clienteId], references: [id])
  clienteId  Int?
}

model Producto {
  id          Int     @id @default(autoincrement())
  precio      Float
  descripcion String
  pedidos Pedido[] @relation(name: "DetalleProductoEnPedido")
}
